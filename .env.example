# ============================================================
# Bookmark Manager — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# Supabase project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service-role key (SERVER SIDE ONLY — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
