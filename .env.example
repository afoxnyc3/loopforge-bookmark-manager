# Supabase — required for all API routes and client-side data fetching
# Get these from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: service role key for server-side admin operations (keep secret, never expose to browser)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Next.js public URL (used for absolute URLs in metadata, sitemap, etc.)
NEXTAUTH_URL=http://localhost:3000
