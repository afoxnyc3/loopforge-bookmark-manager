# ============================================================
# Bookmark Manager — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ============================================================

# ----------------------------------------------------------
# Supabase — Required
# Find these in: Supabase Dashboard → Project Settings → API
# ----------------------------------------------------------

# Your Supabase project URL (used by both client and server)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — SERVER-SIDE ONLY. Never expose to the browser.
# Used by API routes via src/lib/supabase-admin.ts
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ----------------------------------------------------------
# App — Optional
# ----------------------------------------------------------

# Base URL for the application (used for absolute URL generation)
NEXT_PUBLIC_APP_URL=http://localhost:3000
